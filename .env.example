# ─────────────────────────────────────────────────────────────────────────────
# multiqlti environment variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# Generate strong secrets with:
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=multiqlti
# REQUIRED -- change this before first start
POSTGRES_PASSWORD=change_me_before_starting
POSTGRES_DB=multiqlti

# Override the full URL to use an external / managed database:
# DATABASE_URL=postgres://user:pass@your-rds-host:5432/multiqlti?sslmode=require

# ── Security ───────────────────────────────────────────────────────────────
# REQUIRED -- minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_before_starting_generate_with_openssl_rand_hex_32

# Encryption key for workspace connection secrets (AES-256-GCM).
# Used by the workspace_connections table to encrypt third-party credentials.
# REQUIRED in production -- minimum 32 characters. Same key as ENCRYPTION_KEY.
# Alias: MULTI_ENCRYPTION_KEY (takes precedence).
# Generate with: openssl rand -hex 32
CONNECTION_ENCRYPTION_KEY=change_me_before_starting_generate_with_openssl_rand_hex_32

# ── Caddy / TLS ────────────────────────────────────────────────────────────
# Set to your domain for automatic HTTPS via Let's Encrypt.
# Leave as "localhost" for local dev (HTTP only, no cert provisioning).
CADDY_DOMAIN=localhost

# ── Application ────────────────────────────────────────────────────────────
# Only used in dev mode; in production traffic arrives through Caddy on 443.
APP_PORT=5050

# ── Sandbox ────────────────────────────────────────────────────────────────
SANDBOX_ENABLED=true
SANDBOX_MAX_CONCURRENT=3
SANDBOX_DEFAULT_TIMEOUT=120

# ── vLLM ───────────────────────────────────────────────────────────────────
VLLM_MODEL=meta-llama/Meta-Llama-3-70B-Instruct

# ── AI Provider API Keys (for cloud-only or hybrid mode) ──────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# ── Worker Queue (optional -- enables Redis-backed pipeline execution) ────
# REDIS_URL=redis://localhost:6379
# MULTI_FEATURES_WORKER_QUEUE=true

# ── Federation (optional -- multi-instance peer mesh) ─────────────────────
# FEDERATION_ENABLED=true
# FEDERATION_INSTANCE_ID=instance-a
# FEDERATION_INSTANCE_NAME=Igor's Instance
# FEDERATION_CLUSTER_SECRET=shared-secret-min-32-chars
# FEDERATION_PORT=5001
# FEDERATION_PEERS=ws://instance-b:5001,ws://instance-c:5001

# ── Monitoring ─────────────────────────────────────────────────────────────
# Only used when --profile monitoring is active
GRAFANA_PASSWORD=change_me_too
